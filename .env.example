# --- Devin (required) ---
# Service-user token: app.devin.ai -> Settings -> create a service user (token starts with cog_)
DEVIN_API_KEY=cog_...
# Settings -> General -> Organization ID
DEVIN_ORG_ID=org-...
# Created by `python -m scripts.setup playbook`; sessions run without one until set
DEVIN_PLAYBOOK_ID=

# --- GitHub (required) ---
# PAT with issues read/write + pull-request read on the target repo
GITHUB_TOKEN=ghp_...
GITHUB_REPO=willhoff2/superset

# --- Tuning (defaults shown; uncomment to override) ---
#POLL_INTERVAL_ISSUES=30
#POLL_INTERVAL_SESSIONS=15
#MAX_CONCURRENT_SESSIONS=3
#MAX_ACU_DEFAULT=5
#MAX_ACU_MEDIUM=8
#CI_CHECKS_ENABLED=false
#ISSUE_LABEL=devin-remediate
#DONE_LABEL=remediated-pending-merge
#DASHBOARD_PORT=8090
#DB_PATH=data/state.db
#EVENTS_PATH=data/events.jsonl
#LOG_FORMAT=console   # console | json
